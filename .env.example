# Variables requeridas — Copiar a .env y SOBREESCRIBIR para producción
# ⚠️ CAMBIAR TODOS LOS VALORES ANTES DE DESPLEGAR

POSTGRES_USER=hub_admin
POSTGRES_PASSWORD=CAMBIAR_CON openssl rand -base64 24
DATABASE_URL=postgres://hub_admin:CAMBIAR@postgres:5432/hub_platform
JWT_SECRET=CAMBIAR_CON openssl rand -hex 32
JWT_REFRESH_SECRET=CAMBIAR_CON openssl rand -hex 32
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:8081
MAX_LOGIN_ATTEMPTS=5
SEED_ADMIN_PASSWORD=CAMBIAR_CON openssl rand -hex 16
NEXT_PUBLIC_EXTERNAL_SYSTEMS_URL=http://192.168.60.66:8100
