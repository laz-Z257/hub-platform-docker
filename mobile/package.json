    "expo-router": "~56.2.15",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.13",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "^56.0.5",
    "expo-updates": "~56.0.22",
    "lucide-react-native": "^1.17.0",
    "nativewind": "^4.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
