  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start:web": "expo start --web",
    "build:web": "expo export --platform web",
    "web": "npx serve dist",
    "postinstall": "node -e \"const fs=require('fs');const p='node_modules/expo-symbols/build';if(fs.existsSync(p)){if(!fs.existsSync(p+'/android.js'))fs.copyFileSync(p+'/android/index.js',p+'/android.js');if(!fs.existsSync(p+'/symbols.json')&&fs.existsSync(p+'/android/symbols.json'))fs.copyFileSync(p+'/android/symbols.json',p+'/symbols.json');console.log('Patched expo-symbols')}\""
  },
  "private": true
}
