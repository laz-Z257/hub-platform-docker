{
  "cli": {
    "version": ">= 14.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal",
"env": {
        "EXPO_PUBLIC_API_URL": "https://hub-platform-api.onrender.com/api"
      }
    },
    "production": {
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
"env": {
        "EXPO_PUBLIC_API_URL": "https://hub-platform-api.onrender.com/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
